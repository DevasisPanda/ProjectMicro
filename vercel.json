{
  "version": 2,
  "rewrites": [
    {
      "source": "/products",
      "destination": "/api/index"
    },
    {
      "source": "/products/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/public/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/public/styles.css"
    }
  ]
}
